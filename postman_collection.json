{
  "info": {
    "name": "Example API Tests Collection",
    "description": "Collection để kiểm thử tự động bằng Newman. Thay base_url trong environment trước khi chạy",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time under 1000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "pm.test(\"Body contains ok or status\", function () {",
              "  var json = pm.response.json ? pm.response.json() : null;",
              "  if(json) {",
              "    pm.expect(json).to.be.a('object');",
              "  } else {",
              "    pm.expect(pm.response.text()).to.include('ok');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get users list",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200 or 204\", function () {",
              "  pm.expect([200,204]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test(\"If 200 then body is array\", function () {",
              "  if(pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "  }",
              "});",
              "",
              "pm.test(\"Response time under 800ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(800);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Test user\",\"email\":\"testuser+{{timestamp}}@example.com\"}"
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if(!pm.environment.get('timestamp')) {",
              "  pm.environment.set('timestamp', Date.now());",
              "}",
              "var t = pm.environment.get('timestamp');",
              "pm.request.body.update(JSON.stringify({ name: 'Test user', email: 'testuser+' + t + '@example.com' }));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201 or 200\", function () {",
              "  pm.expect([200,201]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test(\"Response contains id and email\", function () {",
              "  var json = pm.response.json();",
              "  if(json) {",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json).to.have.property('email');",
              "    pm.environment.set('created_user_id', json.id);",
              "  }",
              "});",
              "",
              "pm.test(\"Create took under 1000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get user by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{created_user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{created_user_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Body has expected fields\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update user",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Updated test user\"}"
        },
        "url": {
          "raw": "{{base_url}}/users/{{created_user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{created_user_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200 or 204\", function () {",
              "  pm.expect([200,204]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test(\"If 200 then body contains updated name\", function () {",
              "  if(pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('name');",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get posts for user query",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts?userId={{created_user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ],
          "query": [
            {
              "key": "userId",
              "value": "{{created_user_id}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Body is array\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete user",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{created_user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{created_user_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 or 204\", function () {",
              "  pm.expect([200,204,202]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test(\"Delete response time under 1000ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}